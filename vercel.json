{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/optimize",       "dest": "/api/main" },
    { "src": "/pokemon/pool",   "dest": "/api/main" },
    { "src": "/health",         "dest": "/api/main" },
    { "src": "/score",          "dest": "/api/main" },
    { "handle": "filesystem" },
    { "src": "/(.*)",           "dest": "/index.html" }
  ]
}
